# iHotel Multi-Tenant Platform — Environment Configuration
# Copy this file to .env and adjust values for your deployment

# Server
PORT=3000
NODE_ENV=production

# JWT Secret — CHANGE THIS to a random 64-character string in production
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME_strong_random_secret_min_32_chars
JWT_EXPIRY=8h
JWT_REFRESH_EXPIRY=7d

# CORS — set to your frontend URL in production
CORS_ORIGIN=http://localhost:5173

# Rate limiting
LOGIN_RATE_LIMIT=5
LOGIN_RATE_WINDOW_MIN=15

# ── Platform Super Admin ─────────────────────────────────────────────────────
# Seeded into platform_admins table on first run if not already present
PLATFORM_ADMIN_USER=superadmin
PLATFORM_ADMIN_PASS=CHANGE_ME_strong_password

# ── Default Hotel Migration (optional) ──────────────────────────────────────
# Used by migration 010 to create a default hotel from a pre-existing
# single-tenant deployment. Leave blank for a fresh multi-tenant install.
#
# ThingsBoard credentials for the default hotel
TB_HOST=http://localhost:8080
TB_USER=admin@yourdomain.com
TB_PASS=CHANGE_ME

# Slug and name for the migrated default hotel
DEFAULT_HOTEL_SLUG=default
DEFAULT_HOTEL_NAME=Default Hotel
