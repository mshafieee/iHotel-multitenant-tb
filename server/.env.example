# Hilton Grand Hotel IoT Platform — Environment Configuration
# Copy this file to .env and adjust values for your deployment

# Server
PORT=3000
NODE_ENV=production

# ThingsBoard connection
TB_HOST=http://localhost:8080
TB_USER=admin@hiltongrand.com
TB_PASS=hilton

# JWT Secret — CHANGE THIS to a random 64-character string in production
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME_hilton_grand_hotel_super_secret_key_2026
JWT_EXPIRY=8h
JWT_REFRESH_EXPIRY=7d

# CORS — set to your frontend URL in production
CORS_ORIGIN=http://localhost:5173

# Rate limiting
LOGIN_RATE_LIMIT=5
LOGIN_RATE_WINDOW_MIN=15
